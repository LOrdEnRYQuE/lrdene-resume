{
  "name": "lrdene-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "bash scripts/dev-clean.sh",
    "build": "next build",
    "build:safe": "bash scripts/build-safe.sh",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "echo \"No tests configured\" && exit 0",
    "check": "npm run lint && npm run typecheck",
    "preflight:prod": "bash scripts/preflight-prod.sh",
    "deploy:convex": "npx convex deploy",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:deploy": "npx wrangler pages deploy .vercel/output/static --project-name=lrdene-resume --branch=main --commit-dirty=true"
  },
  "dependencies": {
    "convex": "^1.34.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "^15.5.14",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "eslint-config-next": "latest",
    "typescript": "5.9.3",
    "wrangler": "^4.0.0"
  }
}
